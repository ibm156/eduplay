# Copy this to .env and fill in your values

SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Database — leave as sqlite for local dev, switch to postgres for production
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/eduplay

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT token lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
